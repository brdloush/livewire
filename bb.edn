{:min-bb-version "0.8.0"

 :tasks
 {clean
  {:doc "Remove build artifacts (target/ directory)"
   :task (shell "lein clean")}

  compile
  {:doc "Compile Java and Clojure sources"
   :task (shell "lein with-profile +provided compile")}

  jar
  {:doc "Build the JAR (without installing to ~/.m2)"
   :depends [compile]
   :task (shell "lein with-profile +provided jar")}

  install
  {:doc "Build and install livewire to the local Maven repository (~/.m2)"
   :task (shell "lein with-profile +provided install")}

  clean-install
  {:doc "Clean build artifacts, then install to local Maven repository"
   :depends [clean]
   :task (shell "lein with-profile +provided install")}

  source-jar
  {:doc "Build the sources JAR (-sources.jar, required by Maven Central)"
   :task (let [version (nth (read-string (slurp "project.clj")) 2)
               out-dir "target/provided"
               out     (str out-dir "/livewire-" version "-sources.jar")]
           (babashka.fs/create-dirs out-dir)
           (apply shell ["jar" "cf" out "-C" "src/clojure" "." "-C" "src/java" "."])
           (println (str "Created " out)))}

  javadoc-jar
  {:doc "Build a placeholder javadoc JAR (-javadoc.jar, required by Maven Central)"
   :task (let [version (nth (read-string (slurp "project.clj")) 2)
               out-dir "target/provided"
               out     (str out-dir "/livewire-" version "-javadoc.jar")
               doc-dir "target/javadoc"]
           (babashka.fs/create-dirs out-dir)
           (babashka.fs/create-dirs doc-dir)
           (spit (str doc-dir "/README.md")
                 (str "Livewire API documentation is available at "
                      "https://github.com/brdloush/livewire\n"))
           (apply shell ["jar" "cf" out "-C" doc-dir "."])
           (println (str "Created " out)))}

  pom
  {:doc "Generate pom.xml from project.clj"
   :task (shell "lein with-profile +provided pom")}

  release-jars
  {:doc "Build all release artifacts: main JAR, sources JAR, javadoc JAR, and POM"
   :depends [clean jar source-jar javadoc-jar pom]
   :task (let [version (nth (read-string (slurp "project.clj")) 2)]
           (println (str "\nRelease artifacts ready for " version ":"))
           (doseq [f [(str "target/provided/livewire-" version ".jar")
                      (str "target/provided/livewire-" version "-sources.jar")
                      (str "target/provided/livewire-" version "-javadoc.jar")
                      "pom.xml"]]
             (println (str "  " f " — " (if (babashka.fs/exists? f) "✅" "❌")))))}

  stop-serve
  {:doc "Kill the bbserve process on port 4000"
   :task (let [procs (->> (java.lang.ProcessHandle/allProcesses)
                          .iterator
                          iterator-seq
                          (filter (fn [p]
                                    (let [cmd (-> p .info .commandLine)]
                                      (and (.isPresent cmd)
                                           (re-find (re-pattern "bbserve.*--port.*4000") (.get cmd)))))))]
           (if (seq procs)
             (doseq [p procs]
               (.destroy p)
               (println (str "Stopped (pid " (.pid p) ")")))
             (println "No bbserve running on port 4000")))}

  serve
  {:doc "Serve the web/ landing page locally on port 4000 (for development only). Prints a QR code if qrencode is available."
   :task (let [ip   (with-open [s (java.net.DatagramSocket.)]
                      (.connect s (java.net.InetAddress/getByName "8.8.8.8") 53)
                      (.. s getLocalAddress getHostAddress))
               port 4000
               url  (str "http://" ip ":" port)]
           (println (str "→ " url))
           (babashka.process/process ["bbserve" "--dir" "web" "--port" (str port)]
                                     {:out :inherit :err :inherit})
           (Thread/sleep 600)
           (when (babashka.fs/which "qrencode")
             (babashka.process/shell "qrencode" "-t" "ansiutf8" url)))}}}
