[45.629769, "o", "\u001b[?2026h\r\u001b[7A\u001b[38;2;255;255;255mв—Ҹ\u001b[1C\u001b[39m\u001b[1mLivewire\u001b[22m is a\u001b[1Clibrary\u001b[1Cthat\u001b[1Cembeds\u001b[1Can\u001b[1C\u001b[1mnREPL server\u001b[1C\u001b[22m(normally\u001b[1Ca\u001b[1CClojure\u001b[1Ctool)\u001b[1Cdirectly\u001b[1Cinto\u001b[1Cthe\u001b[1CSpring\u001b[1CBoot\u001b[1CJVM\r\u001b[2C\u001b[1Bat startup. Here's how the pieces fit together:                                 \r\u001b[2B  1. \u001b[1mnREPL in the JVM\u001b[22m вҖ” nREPL is just a network protocol for evaluating code. The Livewire dependency starts an \r\u001b[1B  nREPL\u001b[1Cserver\u001b[1C(default\u001b[1Cport\u001b[1C7888)\u001b[1Cinside\u001b[1Cthe\u001b[1Csame\u001b[1CJVM\u001b[1Cprocess\u001b[1Cas\u001b[1Cyour\u001b[1CSpring\u001b[1Capp.\r\u001b[1B  2. \u001b[1mClojure runs on the JVM\u001b[22m вҖ” Since both Java and Clojure compile to JVM bytecode, a Clojure runtime embedded  \r\u001b[2C\u001b[1Bin your Spring app\u001b[1Ccan\u001b[1Ccall\u001b[1Cany\u001b[1CJava\u001b[1Cclass,\u001b[1CSpring\u001b[1Cbean,\u001b[1CHibernate\u001b[1Centity,\u001b[1Cor\u001b[1CJDBC\u001b[1Cconnection\u001b[1Cdirectly\u001b[1CвҖ”\u001b[1Cno\r\r\n\u001b[2Cserialization,\u001b[1Cno\u001b[1CHTTP,\u001b[1Csame\u001b[1Cheap.\r\r\n\u001b[2C3.\u001b[1C\u001b[1mSpring\u001b[1Ccontext\u001b[1Cis\u001b[1Caccessible\u001b[1C\u001b[22mвҖ”\u001b[1CLivewire\u001b[1Cimplements\u001b[1C\u001b[38;2;177;185;249mApplicationContextAware\u001b[39m,\u001b[1Cso\u001b[1Cwhen\u001b[1CSpring\u001b[1Cboots\u001b[1Cup\u001b[1Cit\r\r\n\u001b[2Chands\u001b[1Cthe\u001b[1C\u001b[38;2;177;185;249mApplicationContext\u001b[1C\u001b[39mto\u001b[1CLivewire.\u001b[1CThat's\u001b[1Chow\u001b[1C\u001b[38;2;177;185;249m(lw/bean\u001b[1C\"bookRepository\")\u001b[1C\u001b[39mworks\u001b[1CвҖ”\u001b[1Cit's\u001b[1Cliterally\u001b[1Ccalling\r\r\n\u001b[3C\u001b[38;2;177;185;249mctx.getBean(\"bookRepository\")\u001b[1C\u001b[39mfrom\u001b[1CClojure.\r\r\n\u001b[2C4.\u001b[1C\u001b[38;2;177;185;249m\u001b[1mclj-nrepl-eval\u001b[1C\u001b[22m\u001b[39mвҖ”\u001b[1Cthe\u001b[1CCLI\u001b[1Ctool\u001b[1Con\u001b[1Cyour\u001b[1Cmachine\u001b[1Csends\u001b[1CClojure\u001b[1Cexpressions\u001b[1Cover\u001b[1Ca\u001b[1Csocket\u001b[1Cto\u001b[1Cthat\u001b[1Cembedded\r\r\n\u001b[2CnREPL\u001b[1Cserver,\u001b[1Cgets\u001b[1Cresults\u001b[1Cback,\u001b[1Cand\u001b[1Cprints\u001b[1Cthem.\r\r\n\r\r\n\u001b[2CSo\u001b[1Cthe\u001b[1Cflow\u001b[1Cis:\r\r\n\r\r\n\u001b[2Cyour\u001b[1Cshell\r\r\n\u001b[4CвҶ’\u001b[1Cclj-nrepl-eval\u001b[1C(socket\u001b[1Cclient)\r\r\n\u001b[6CвҶ’\u001b[1CnREPL\u001b[1Cserver\u001b[1C(embedded\u001b[1Cin\u001b[1CSpring\u001b[1CBoot\u001b[1CJVM)\r\r\n\u001b[8CвҶ’\u001b[1CClojure\u001b[1Cruntime\u001b[1C(same\u001b[1CJVM)\r\r\n\u001b[10CвҶ’\u001b[1CSpring\u001b[1Cbeans,\u001b[1CHibernate,\u001b[1CJDBC\u001b[1C(same\u001b[1Cheap)\r\r\n\r\r\n\u001b[2CNo\u001b[1Crestart\u001b[1Cneeded,\u001b[1Cno\u001b[1Cagent,\u001b[1Cno\u001b[1CJMX,\u001b[1Cno\u001b[1Cspecial\u001b[1CJava\u001b[1Cagent\u001b[1CвҖ”\u001b[1Cjust\u001b[1Ca\u001b[1Cdependency\u001b[1Con\u001b[1Cthe\u001b[1Cclasspath\u001b[1Cthat\u001b[1Cboots\u001b[1Can\r\r\n\u001b[2CnREPL\u001b[1Clistener.\u001b[1CThe\u001b[1C\u001b[38;2;177;185;249mlivewire.enabled=true\u001b[1C\u001b[39mproperty\u001b[1Cgates\u001b[1Cit\u001b[1Cso\u001b[1Cit\u001b[1Conly\u001b[1Cactivates\u001b[1Cin\u001b[1C\u001b[38;2;177;185;249mdev\u001b[1C\u001b[39m(which\u001b[1Cmatches\u001b[1Cyour\r\r\n\u001b[2Cactive\u001b[1Cprofiles).\r\r\n\r\r\n\u001b[38;2;136;136;136mв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\u001b[39m\r\r\nвқҜВ \u001b[7m \u001b[27m\r\r\n\u001b[38;2;136;136;136mв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”