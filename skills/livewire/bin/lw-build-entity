#!/usr/bin/env bash
# Usage: lw-build-entity <EntityName> [edn-opts]
# Builds a Hibernate entity instance populated with realistic fake data.
#
# Arguments:
#   EntityName   — simple Hibernate entity name, e.g. Author, Book, Review
#   edn-opts     — optional EDN map, e.g. '{:auto-deps? true :persist? true :rollback? true}'
#
# Examples:
#   lw-build-entity Author
#   lw-build-entity Book '{:auto-deps? true}'
#   lw-build-entity Review '{:auto-deps? true :persist? true :rollback? true}'
clj-nrepl-eval -p "${LW_PORT:-7888}" \
  "(require '[net.brdloush.livewire.core :as lw] '[net.brdloush.livewire.query :as q] '[net.brdloush.livewire.introspect :as intro] '[net.brdloush.livewire.trace :as trace] '[net.brdloush.livewire.query-watcher :as qw] '[net.brdloush.livewire.hot-queries :as hq] '[net.brdloush.livewire.jpa-query :as jpa] '[net.brdloush.livewire.mvc :as mvc] '[net.brdloush.livewire.faker :as faker])"
if [ -z "$2" ]; then
  exec clj-nrepl-eval -p "${LW_PORT:-7888}" "(faker/build-entity \"$1\")"
else
  exec clj-nrepl-eval -p "${LW_PORT:-7888}" "(faker/build-entity \"$1\" $2)"
fi
