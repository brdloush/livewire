#!/usr/bin/env bash
# Usage: lw-inspect-all-entities
#
# Returns full Hibernate metamodel detail for every entity in the persistence
# unit in a single call — equivalent to running lw-inspect-entity for each
# entity individually, but without the per-entity round-trip overhead.
#
# Output: map of {entity-simple-name -> inspect-entity result}
clj-nrepl-eval -p "${LW_PORT:-7888}" \
  "(require '[net.brdloush.livewire.core :as lw] '[net.brdloush.livewire.query :as q] '[net.brdloush.livewire.introspect :as intro] '[net.brdloush.livewire.trace :as trace] '[net.brdloush.livewire.query-watcher :as qw] '[net.brdloush.livewire.hot-queries :as hq] '[net.brdloush.livewire.jpa-query :as jpa] '[net.brdloush.livewire.mvc :as mvc])"
exec clj-nrepl-eval -p "${LW_PORT:-7888}" "(intro/inspect-all-entities)"
