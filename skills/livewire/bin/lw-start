#!/usr/bin/env bash
# Usage: lw-start
#
# Discovers running nREPL servers and, once connected, reports an app summary.
# Combines the two manual startup steps into one:
#   1. clj-nrepl-eval --discover-ports
#   2. lw-info  (app name, profiles, Java/Spring/Hibernate versions)

clj-nrepl-eval --discover-ports
clj-nrepl-eval -p "${LW_PORT:-7888}" \
  "(require '[net.brdloush.livewire.core :as lw] '[net.brdloush.livewire.query :as q] '[net.brdloush.livewire.introspect :as intro] '[net.brdloush.livewire.trace :as trace] '[net.brdloush.livewire.query-watcher :as qw] '[net.brdloush.livewire.hot-queries :as hq] '[net.brdloush.livewire.jpa-query :as jpa] '[net.brdloush.livewire.mvc :as mvc])"
exec clj-nrepl-eval -p "${LW_PORT:-7888}" "(lw/info)"
